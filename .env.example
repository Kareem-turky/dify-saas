# API local defaults
DATABASE_URL="file:./dev.db"

# Auth bootstrap for first admin user and local token signing.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
AUTH_TOKEN_SECRET="change-this-local-secret"

# Local payment proof storage for development. Use S3/R2/MinIO in production.
PAYMENT_PROOF_UPLOAD_DIR="./uploads/payment-proofs"

# Dify provisioning is safe dry-run by default.
DIFY_WORKSPACE_MODE="dry-run"

# Required only when DIFY_WORKSPACE_MODE="live".
# DIFY_BASE_URL="https://your-dify.example.com"
# DIFY_ADMIN_TOKEN="replace-me-with-dify-INNER_API_KEY"

# Customer AI Studio link shown after organization becomes active.
# Default if unset: https://studio.local/tenants/{tenantId}
# DIFY_CONSOLE_BASE_URL="https://studio.your-domain.com"
# DIFY_WORKSPACE_URL_TEMPLATE="https://studio.your-domain.com/console?tenant={tenantId}&org={organizationId}"

# Web app talks to API.
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"
