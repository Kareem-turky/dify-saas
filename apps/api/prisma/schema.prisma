generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id
  name              String
  email             String        @unique
  phone             String?
  role              String
  passwordHash      String?
  preferredLanguage String
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  auditLogs         AuditLog[]
  updatedChannels   Channel[]
}

model Organization {
  id            String             @id
  name          String
  ownerUserId   String
  status        String
  industry      String?
  difyTenantId  String?
  difyAccountId String?
  users         User[]
  subscriptions Subscription[]
  payments      Payment[]
  paymentProofs PaymentProof[]
  approvals     ApprovalRequest[]
  jobs          ProvisioningJob[]
  channels      Channel[]
  messageEvents MessageEvent[]
  auditLogs     AuditLog[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model Plan {
  id                     String         @id
  name                   String
  monthlyPriceEgp        Int
  messageLimit           Int
  channelLimit           Int
  seatLimit              Int
  requiresManualApproval Boolean
  subscriptions          Subscription[]
}

model Subscription {
  id             String       @id
  organizationId String
  planId         String
  status         String
  organization   Organization @relation(fields: [organizationId], references: [id])
  plan           Plan         @relation(fields: [planId], references: [id])
  payments       Payment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Payment {
  id             String            @id
  organizationId String
  subscriptionId String
  method         String
  amountEgp      Int
  status         String
  reference      String?
  proofUrl       String?
  organization   Organization      @relation(fields: [organizationId], references: [id])
  subscription   Subscription      @relation(fields: [subscriptionId], references: [id])
  approvals      ApprovalRequest[]
  proofs         PaymentProof[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model PaymentProof {
  id             String       @id
  organizationId String
  paymentId      String?
  storageKey     String
  proofUrl       String
  originalName   String
  mimeType       String
  sizeBytes      Int
  sha256         String
  status         String       @default("uploaded")
  organization   Organization @relation(fields: [organizationId], references: [id])
  payment        Payment?     @relation(fields: [paymentId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([paymentId])
}

model ApprovalRequest {
  id             String       @id
  organizationId String
  paymentId      String
  status         String
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  payment        Payment      @relation(fields: [paymentId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ProvisioningJob {
  id             String       @id
  organizationId String
  type           String
  status         String
  attempts       Int          @default(0)
  maxAttempts    Int          @default(3)
  nextRunAt      DateTime?
  payload        Json
  lastError      String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status, nextRunAt])
}

model AuditLog {
  id             String        @id
  actorUserId    String?
  organizationId String?
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  actorUser      User?         @relation(fields: [actorUserId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())

  @@index([actorUserId])
  @@index([organizationId])
  @@index([action])
  @@index([createdAt])
}

model Channel {
  id                   String       @id
  organizationId       String
  channelType          String
  phoneNumberId        String?
  wabaId               String?
  accessTokenHash      String?
  verifyToken          String?
  appSecretHash        String?
  status               String       @default("configured")
  lastError            String?
  updatedByUserId      String?
  organization         Organization @relation(fields: [organizationId], references: [id])
  updatedByUser        User?        @relation(fields: [updatedByUserId], references: [id])
  messageEvents        MessageEvent[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([organizationId, channelType])
  @@index([channelType, phoneNumberId])
  @@index([status])
}

model MessageEvent {
  id             String       @id
  organizationId String
  channelId      String
  channelType    String
  direction      String
  eventId        String       @unique
  fromId         String?
  toId           String?
  messageType    String?
  textBody       String?
  rawPayload     Json
  status         String       @default("received")
  organization   Organization @relation(fields: [organizationId], references: [id])
  channel        Channel      @relation(fields: [channelId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, createdAt])
  @@index([channelId, createdAt])
  @@index([status])
}
